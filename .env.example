NODE_ENV=production
PORT=5000

# DATABASE - MongoDB Atlas URL for production
MONGO_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# FRONTEND URL (e.g. your Vercel deployment URL)
CLIENT_URL=

# RAILWAY SPECIFIC (Optional, filled by Railway)
RAILWAY_PUBLIC_DOMAIN=

# WHATSAPP META API
WEBHOOK_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ENCRYPTION (exactly 32 chars)
ENCRYPTION_KEY=

# ADMIN
ADMIN_MOBILE=

# TWILIO (if using)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
